# Bar segment intake (match pdf-backend / CID-PDF-API where applicable)
PORT=8787
SEGMENT=bar

# Postgres (submissions + duplicate detection + client_submission document row)
DATABASE_URL=
# PGSSLMODE=disable

# Gmail send (packet + notifyBarSubmissionReceived)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Default recipient for outbound packet if request body omits email.to
# CARRIER_EMAIL=
# CLIENT_SUBMISSION_EMAIL_TO=

# Cloudflare R2 (client_submission PDF upload + documents row)
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Puppeteer (same as CID-PDF-API on Render — path to Chromium)
PUPPETEER_EXECUTABLE_PATH=

# Optional: same Supabase as operator (only if you use db.js Supabase helpers)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
